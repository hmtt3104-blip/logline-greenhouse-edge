# Copy to .env for local testing. Do not commit .env.

GREENHOUSE_BRIDGE_TELEGRAM_BOT_TOKEN=
GREENHOUSE_BRIDGE_TELEGRAM_CHAT_ID=
GREENHOUSE_BRIDGE_TELEGRAM_EGRESS_ENABLED=0

GREENHOUSE_BRIDGE_MQTT_HOST=MQTT_BROKER_HOST
GREENHOUSE_BRIDGE_MQTT_PORT=1883

GREENHOUSE_BRIDGE_GREENHOUSE1_BASE_URL=http://greenhouse-device.local
GREENHOUSE_BRIDGE_GREENHOUSE2_BASE_URL=http://greenhouse-device-2.local
GREENHOUSE_BRIDGE_TEMPERATURE_NODE_BASE_URL=
GREENHOUSE_BRIDGE_GREENHOUSE_CONTROL_TIMEOUT_SEC=5

GREENHOUSE_BRIDGE_DIRECT_CONTROL_HOST=127.0.0.1
GREENHOUSE_BRIDGE_DIRECT_CONTROL_PORT=8787
GREENHOUSE_BRIDGE_LOG_LEVEL=INFO

GREENHOUSE_BRIDGE_COMMAND_POLLING_ENABLED=0
GREENHOUSE_BRIDGE_LEGACY_COMMAND_INGRESS_ENABLED=0
GREENHOUSE_BRIDGE_DRY_RUN=1

GREENHOUSE_BRIDGE_FIREBASE_ENABLED=0
GREENHOUSE_BRIDGE_FIREBASE_DATABASE_URL=https://example-project-default-rtdb.firebaseio.com
GREENHOUSE_BRIDGE_FIREBASE_SERVICE_ACCOUNT_JSON=
GREENHOUSE_BRIDGE_GREENHOUSE_ID=greenhouse2
GREENHOUSE_BRIDGE_FIREBASE_G1_STATE_PATH=examples/greenhouse1/state
GREENHOUSE_BRIDGE_FIREBASE_G1_COMMANDS_PENDING_PATH=examples/greenhouse1/commands/pending
GREENHOUSE_BRIDGE_FIREBASE_G1_COMMANDS_HISTORY_PATH=examples/greenhouse1/commands/history
GREENHOUSE_BRIDGE_FIREBASE_G2_STATE_PATH=examples/greenhouse2/state
GREENHOUSE_BRIDGE_FIREBASE_G2_COMMANDS_PENDING_PATH=examples/greenhouse2/commands/pending
GREENHOUSE_BRIDGE_FIREBASE_G2_COMMANDS_HISTORY_PATH=examples/greenhouse2/commands/history
GREENHOUSE_BRIDGE_FIREBASE_T3_STATE_PATH=examples/temperature-node/state
GREENHOUSE_BRIDGE_FIREBASE_PROCESSING_BY=logline_greenhouse_edge
GREENHOUSE_BRIDGE_POLL_INTERVAL_SEC=1.0
GREENHOUSE_BRIDGE_COMMAND_EXPIRE_SEC=90
GREENHOUSE_BRIDGE_STALE_STATE_SEC=45

DUALZONE_LOGGER_BASE_URL=http://greenhouse-device.local
DUALZONE_LOGGER_OUT_DIR=data/dualzone-web-logs
DUALZONE_LOGGER_STATUS_INTERVAL_SEC=5
DUALZONE_LOGGER_EVENTS_INTERVAL_SEC=2
DUALZONE_LOGGER_TIMEOUT_SEC=8
DUALZONE_LOGGER_EVENTS_LIMIT=200

SINGLEZONE_LOGGER_BASE_URL=http://greenhouse-device-2.local
SINGLEZONE_LOGGER_OUT_DIR=data/singlezone-web-logs
SINGLEZONE_LOGGER_STATUS_INTERVAL_SEC=5
SINGLEZONE_LOGGER_TIMEOUT_SEC=8
